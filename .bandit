# Bandit security scanner configuration
# https://bandit.readthedocs.io/en/latest/config.html

skips:
  - B101
  - B110
  - B112
  - B311
  - B404
  - B603
  - B607

exclude_dirs:
  - .venv
  - env
  - __pycache__
  - node_modules
  - .git
  - .eggs
  - .mypy_cache
  - .pytest_cache
  - .github
  - pdf-Header_Image_Extractor
